# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# Environment — NEVER commit real secrets
.env
.env.local
.env.*.local
!.env.example

# Node
node_modules/
dist/
.cache/

# Logs
*.log
*.txt.bak

# OS
.DS_Store
Thumbs.db

# Docker volumes
pgdata/

# Scratch / debug files
scratch/
*.db
datasets/debug_*.txt
datasets/insert_test*.sql

# SQL dataset files
# ALL raw .sql files are Git LFS pointers — Coolify can't use them.
# The compressed .gz versions are tracked as regular git files.
datasets/*.sql
!datasets/*.sql.gz
