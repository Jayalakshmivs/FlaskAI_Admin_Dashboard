# ============================================================
# FlaskAI Admin Dashboard - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --------------- General ---------------
ENVIRONMENT=production
SECRET_KEY=your-random-secret-key-min-32-chars

# --------------- PostgreSQL ---------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-db-password
POSTGRES_DB=flaskai
POSTGRES_PORT=5432

# Full connection string (hostname "db" = Docker service name)
DATABASE_URL=postgresql://postgres:your-strong-db-password@db:5432/flaskai

# --------------- Backend (FastAPI) ---------------
BACKEND_PORT=8000
BACKEND_WORKERS=4
# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=https://yourdomain.com

# --------------- Frontend (Vite / React) ---------------
FRONTEND_PORT=5173
VITE_API_URL=/api
NODE_ENV=production

# --------------- Google SSO (OAuth) ---------------
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --------------- pgAdmin (optional) ---------------
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=your-pgadmin-password
