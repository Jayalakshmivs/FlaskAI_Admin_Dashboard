# PostgreSQL connection string for local backend development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flaskai

# Docker Compose defaults
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=flaskai
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=5173
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@flaskai.com
PGADMIN_DEFAULT_PASSWORD=admin
